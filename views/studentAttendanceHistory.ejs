<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance History | Attendify</title>
    <link rel="stylesheet" href="/css/studentSchedule.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <style>
        /* Specific History Styles */
        .history-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 24px;
        }

        .subject-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 24px;
            transition: var(--transition);
            display: flex;
            flex-direction: column;
            gap: 16px;
            box-shadow: var(--shadow-sm);
        }

        .subject-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow);
            border-color: var(--primary);
        }

        .subject-info h3 {
            font-size: 18px;
            font-weight: 800;
            margin-bottom: 4px;
            color: var(--text);
        }

        .subject-info p {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 600;
        }

        .subject-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            padding: 16px;
            background: var(--surface-2);
            border-radius: var(--radius);
        }

        .stat-item {
            text-align: center;
        }

        .stat-item span {
            display: block;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        .stat-item strong {
            font-size: 18px;
            font-weight: 800;
            color: var(--text);
        }

        .stat-item.active strong {
            color: var(--primary);
        }

        .percentage-bar-wrap {
            width: 100%;
            height: 8px;
            background: #e2e8f0;
            border-radius: 99px;
            overflow: hidden;
            margin-top: 8px;
        }

        .percentage-bar {
            height: 100%;
            border-radius: 99px;
            transition: width 1s ease-out;
        }

        .bar-high {
            background: var(--success);
        }

        .bar-mid {
            background: var(--warning);
        }

        .bar-low {
            background: var(--danger);
        }

        .percentage-badge {
            font-size: 11px;
            font-weight: 800;
            padding: 4px 10px;
            border-radius: 99px;
            text-transform: uppercase;
        }

        .badge-high {
            background: #dcfce7;
            color: var(--success);
        }

        .badge-mid {
            background: #fef9c3;
            color: var(--warning);
        }

        .badge-low {
            background: #fee2e2;
            color: var(--danger);
        }

        .card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .donut {
            --percent: 0;
            --size: 120px;
            --thickness: 10px;
            --color: var(--primary);
            --bg-donut: #f1f5f9;
            width: var(--size);
            height: var(--size);
            border-radius: 50%;
            display: grid;
            place-items: center;
            background: radial-gradient(closest-side, transparent 100%, white 0),
                conic-gradient(var(--color) calc(var(--percent) * 1%), var(--bg-donut) 0);
            position: relative;
            font-weight: 800;
            font-size: 22px;
            box-shadow: var(--shadow-sm);
        }

        .donut::before {
            content: "";
            position: absolute;
            width: calc(var(--size) - var(--thickness) * 2);
            height: calc(var(--size) - var(--thickness) * 2);
            background: var(--surface);
            border-radius: 50%;
        }

        .donut span {
            position: relative;
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .donut small {
            font-size: 10px;
            font-weight: 600;
            color: var(--text-muted);
            margin-top: -4px;
        }

        .overall-summary {
            background: linear-gradient(135deg, var(--primary), #6366f1);
            background-color: #6366f1;
            color: #fff;
            border-radius: var(--radius-xl);
            padding: 32px;
            margin-bottom: 32px;
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 40px;
            align-items: center;
            box-shadow: var(--shadow-lg);
            width: 100%;
        }

        .overall-donut-wrap {
            display: flex;
            justify-content: center;
        }

        .overall-stats-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }

        .overall-stat-box h4 {
            font-size: 14px;
            opacity: 0.8;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .overall-stat-box strong {
            font-size: 32px;
            font-weight: 800;
        }

        .timeline-section {
            margin-bottom: 48px;
        }

        .timeline-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
        }

        .month-selector {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 24px;
            font-weight: 800;
            color: var(--text);
            cursor: pointer;
        }

        .timeline-grid {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .session-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: var(--transition);
            box-shadow: var(--shadow-sm);
        }

        .session-card:hover {
            box-shadow: var(--shadow);
            transform: translateY(-2px);
        }

        .session-content {
            padding: 20px 24px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .session-main h3 {
            font-size: 17px;
            font-weight: 700;
            margin: 8px 0 4px;
        }

        .session-type {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .session-type i {
            color: var(--primary);
        }

        .session-time {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-muted);
        }

        .status-bar {
            width: 100%;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 14px;
            gap: 10px;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }

        .status-bar.present {
            background: #e0e7ff;
            color: var(--primary);
        }

        .status-bar.absent {
            background: #fee2e2;
            color: var(--danger);
        }

        .status-bar.live {
            background: var(--primary);
            color: #fff;
            cursor: pointer;
        }

        .status-bar.live:hover {
            background: var(--primary-dark);
        }

        .no-data {
            text-align: center;
            padding: 64px 0;
            color: var(--text-muted);
        }

        .no-data i {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.5;
        }

        @media (max-width: 768px) {
            .overall-summary {
                grid-template-columns: 1fr;
                text-align: center;
                gap: 32px;
            }

            .overall-stats-row {
                gap: 16px;
            }

            .overall-stat-box strong {
                font-size: 24px;
            }
        }
    </style>
</head>

<body>

    <% const firstName=student.fullName.split(" ")[0]; %>

    <div class=" schedule-layout">

        <aside class="schedule-sidebar">
            <div class="student-welcome">
                <div class="welcome-icon">
                    <i class="fa-solid fa-hand"></i>
                </div>
                <h2>Hi <%= firstName %>!</h2>
            </div>

            <nav class="sidebar-menu">
                <a href="/student/dashboard" class="menu-item">
                    <i class="fa-solid fa-house"></i>
                    <span>Home</span>
                </a>

                <a href="/student/schedule" class="menu-item">
                    <i class="fa-solid fa-calendar-days"></i>
                    <span>Schedule</span>
                </a>

                <a href="#" class="menu-item">
                    <i class="fa-solid fa-users"></i>
                    <span>Community</span>
                </a>

                <a href="/student/attendance-history" class="menu-item active">
                    <i class="fa-solid fa-chart-simple"></i>
                    <span>My Attendance</span>
                </a>

                <a href="#" class="menu-item">
                    <i class="fa-solid fa-credit-card"></i>
                    <span>Fee Payment</span>
                    <b></b>
                </a>

                <a href="#" class="menu-item">
                    <i class="fa-solid fa-book-open"></i>
                    <span>My Courses</span>
                </a>
            </nav>

            <div class="academy-link">
                <a href="#" class="menu-item">
                    <i class="fa-solid fa-circle-play"></i>
                    <span>Mirai Academy</span>
                </a>
            </div>

            <p class="settings-title">Settings</p>

            <form action="/logout" method="POST">
                <button class="menu-item logout-btn" type="submit">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i>
                    <span>Log Out</span>
                </button>
            </form>
        </aside>

        <main class="schedule-main">

            <header class="dashboard-header" style="margin-bottom: 32px;">
                <div style="display: flex; align-items: center; gap: 16px;">
                    <a href="/student/dashboard" class="back-btn"
                        style="background: var(--surface); border: 1px solid var(--border); width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; border-radius: 12px; color: var(--text);"><i
                            class="fa-solid fa-arrow-left"></i></a>
                    <div>
                        <span class="dashboard-kicker">Analysis</span>
                        <h1>Attendance History</h1>
                    </div>
                </div>

                <div
                    style="background: var(--surface); border: 1px solid var(--border); padding: 0 16px; height: 44px; display: flex; align-items: center; border-radius: 12px; font-weight: 700; font-size: 14px; gap: 8px;">
                    <i class="fa-solid fa-calendar-day" style="color: var(--primary);"></i>
                    <%= today %>
                </div>
            </header>

            <section class="overall-summary animate-in">
                <div class="overall-donut-wrap">
                    <div class="donut"
                        style="--percent:<%= stats.overallPercentage %>; --size: 140px; --thickness: 12px; --color: #fff; --bg-donut: rgba(255,255,255,0.2);">
                        <span>
                            <%= stats.overallPercentage %>%
                                <small>OVERALL</small>
                        </span>
                    </div>
                </div>
                <div class="overall-info">
                    <div class="overall-stats-row">
                        <div class="overall-stat-box">
                            <h4>Total Classes</h4>
                            <strong>
                                <%= stats.totalSessions %>
                            </strong>
                        </div>
                        <div class="overall-stat-box">
                            <h4>Present</h4>
                            <strong>
                                <%= stats.totalPresent %>
                            </strong>
                        </div>
                        <div class="overall-stat-box">
                            <h4>Absent</h4>
                            <strong>
                                <%= stats.totalAbsent %>
                            </strong>
                        </div>
                    </div>
                    <p style="margin-top: 24px; font-size: 15px; opacity: 0.9; line-height: 1.5; font-weight: 500;">
                        Your attendance is calculated based on <%= stats.totalSessions %> sessions conducted for <%=
                                student.classGroup.name %>.
                    </p>
                </div>
            </section>

            <section class="timeline-section animate-in">
                <div class="timeline-header">
                    <div class="month-selector">
                        <%= new Date().toLocaleString('default', { month: 'long' }) %>
                            <i class="fa-solid fa-angle-down" style="font-size: 16px; margin-left: 8px;"></i>
                    </div>
                    <div class="timeline-actions" style="display: flex; gap: 12px; align-items: center;">
                        <button class="icon-btn"
                            style="background: var(--surface); border: 1px solid var(--border); width: 44px; height: 44px; border-radius: 12px;"><i
                                class="fa-solid fa-rotate-right"></i></button>
                        <div
                            style="background: var(--surface); border: 1px solid var(--border); padding: 0 16px; height: 44px; display: flex; align-items: center; border-radius: 12px; font-weight: 800; font-size: 15px;">
                            <%= new Date().getDate() %>
                        </div>
                    </div>
                </div>

                <div class="timeline-grid">
                    <% if (timeline && timeline.length> 0) { %>
                        <% timeline.forEach(function(session) { %>
                            <div class="session-card">
                                <div class="session-content">
                                    <div class="session-main">
                                        <span class="session-type">
                                            <i class="fa-solid fa-graduation-cap"></i>
                                            Core Subject
                                        </span>
                                        <h3>
                                            <%= session.subject.subjectName %>
                                        </h3>
                                        <p style="font-size: 12px; color: var(--text-muted); font-weight: 600;">Core •
                                            <%= student.classGroup.name %>
                                        </p>
                                    </div>
                                    <div class="session-time">
                                        <%= session.startTime %> - <%= session.endTime %>
                                    </div>
                                </div>

                                <% if (session.status==='PRESENT' || session.status==='LATE' ) { %>
                                    <div class="status-bar present">
                                        <i class="fa-solid fa-circle-check"></i>
                                        Marked Present
                                    </div>
                                    <% } else if (session.status==='ABSENT' ) { %>
                                        <div class="status-bar absent">
                                            <i class="fa-solid fa-circle-xmark"></i>
                                            Marked Absent
                                        </div>
                                        <% } else if (session.status==='LIVE' ) { %>
                                            <div class="status-bar live"
                                                onclick="window.location.href='/student/dashboard'">
                                                <i class="fa-solid fa-circle-play"></i>
                                                Mark Attendance
                                            </div>
                                            <% } %>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="no-data"
                                        style="background: var(--surface); border-radius: var(--radius-lg); border: 1px dashed var(--border);">
                                        <i class="fa-solid fa-calendar-day"></i>
                                        <h3>No classes for today</h3>
                                        <p>Your schedule is clear for today.</p>
                                    </div>
                                    <% } %>
                </div>
            </section>

            <div class="section-header"
                style="display: flex; justify-content: space-between; align-items: center; margin-top: 40px;">
                <h2 style="font-size: 22px; font-weight: 800;">Subject-wise Analysis</h2>
                <div class="filter-chip">
                    <span>Recent Session</span>
                    <i class="fa-solid fa-angle-down"></i>
                </div>
            </div>

            <div class="history-grid">
                <% if (subjectStats && subjectStats.length> 0) { %>
                    <% subjectStats.forEach(function(sub) { %>
                        <% let tint='mid' ; if (sub.percentage>= 75) tint = 'high';
                            else if (sub.percentage < 50) tint='low' ; %>
                                <div class="subject-card animate-in">
                                    <div class="subject-info">
                                        <h3>
                                            <%= sub.name %>
                                        </h3>
                                        <p>
                                            <%= sub.code %>
                                        </p>
                                    </div>

                                    <div class="subject-stats">
                                        <div class="stat-item">
                                            <span>Total</span>
                                            <strong>
                                                <%= sub.total %>
                                            </strong>
                                        </div>
                                        <div class="stat-item active">
                                            <span>Present</span>
                                            <strong>
                                                <%= sub.present %>
                                            </strong>
                                        </div>
                                        <div class="stat-item">
                                            <span>Absent</span>
                                            <strong>
                                                <%= sub.absent %>
                                            </strong>
                                        </div>
                                    </div>

                                    <div>
                                        <div class="card-footer">
                                            <span class="text-muted"
                                                style="font-size: 12px; font-weight: 700;">ATTENDANCE RATE</span>
                                            <span class="percentage-badge badge-<%= tint %>">
                                                <%= sub.percentage %>%
                                            </span>
                                        </div>
                                        <div class="percentage-bar-wrap">
                                            <div class="percentage-bar bar-<%= tint %>"
                                                style="--w: <%= sub.percentage %>%; width: var(--w);"></div>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div class="no-data">
                                            <i class="fa-solid fa-book-open"></i>
                                            <h3>No subjects found</h3>
                                            <p>You are not enrolled in any subjects yet.</p>
                                        </div>
                                        <% } %>
            </div>

        </main>

        <aside class="profile-panel">
            <div class="profile-card">
                <div class="avatar-circle">
                    <%= student.fullName.charAt(0).toUpperCase() %>
                </div>

                <div>
                    <h3>
                        <%= student.fullName %>
                    </h3>
                    <a href="#">Open Profile</a>
                </div>
            </div>

            <div class="side-card">
                <div class="side-card-icon blue">
                    <i class="fa-solid fa-users-rectangle"></i>
                </div>
                <div>
                    <h4>Class Group</h4>
                    <% if (student.classGroup && student.classGroup.name) { %>
                        <p>
                            <%= student.classGroup.name %>
                        </p>
                        <% } else { %>
                            <p>N/A</p>
                            <% } %>
                </div>
            </div>

            <div class="side-card">
                <div class="side-card-icon purple">
                    <i class="fa-solid fa-book-open"></i>
                </div>
                <div>
                    <h4>Subjects</h4>
                    <% if (student.subjects) { %>
                        <p>
                            <%= student.subjects.length %> Subjects
                        </p>
                        <% } else { %>
                            <p>0 Subjects</p>
                            <% } %>
                </div>
            </div>

            <div class="side-card">
                <div class="side-card-icon green">
                    <i class="fa-solid fa-broadcast-tower"></i>
                </div>
                <div>
                    <h4>Live Sessions</h4>
                    <p>
                        <%= activeSessions.length %> Active
                    </p>
                </div>
            </div>

            <div class="side-card">
                <div class="side-card-icon green">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <div>
                    <h4>Present Today</h4>
                    <p>
                        <%= presentCount %> Classes
                    </p>
                </div>
            </div>

            <div class="side-card">
                <div class="side-card-icon purple">
                    <i class="fa-solid fa-circle-xmark"></i>
                </div>
                <div>
                    <h4>Absent Today</h4>
                    <p>
                        <%= absentCount %> Classes
                    </p>
                </div>
            </div>
        </aside>

        </div>

</body>
<script src="/js/studentLocation.js"></script>

</html>