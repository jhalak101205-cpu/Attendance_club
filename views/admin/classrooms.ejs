<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Classrooms | Admin</title>
    <link rel="stylesheet" href="/css/adminTheme.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/css/adminTheme.css">

<link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
>
</head>
<body>

<div class="admin-layout">
    <%- include("partials/sidebar", { activePage: activePage }) %>

    <main class="admin-main">
        <header class="admin-header">
            <div>
                <span class="admin-kicker">Admin Panel</span>
                <h1>Classrooms</h1>
                <p>Create, search, and manage classroom locations for attendance.</p>
            </div>
        </header>

        <% if (message) { %>
            <div class="admin-alert success"><%= message %></div>
        <% } %>

        <section class="admin-card">
            <div class="admin-card-head">
                <div>
                    <h3>Add Classroom</h3>
                    <p>Latitude, longitude and radius are used for location verification.</p>
                </div>
            </div>

            <form action="/admin/classrooms/create" method="POST" class="admin-form-grid">
                <input type="text" name="classroomName" placeholder="Classroom Name" required>
                <input type="text" name="buildingName" placeholder="Building Name" required>
                <input type="number" name="floorNumber" placeholder="Floor Number" required>
                <input type="number" step="any" name="latitude" placeholder="Latitude" required>
                <input type="number" step="any" name="longitude" placeholder="Longitude" required>
                <input type="number" name="radius" placeholder="Radius in meters" value="100">

                <button class="admin-primary-btn" type="submit">
                    <i class="fa-solid fa-plus"></i>
                    Add Classroom
                </button>
            </form>
        </section>

        <section class="admin-card">
            <div class="admin-toolbar">
                <div class="admin-search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input
                        type="text"
                        data-admin-search="classrooms"
                        placeholder="Search classroom by name, building, floor, latitude or longitude..."
                    >
                </div>

                <span class="admin-count-pill">
                    <%= classrooms.length %> Classrooms
                </span>
            </div>

            <% if (classrooms.length === 0) { %>
                <div class="admin-empty">No classrooms found.</div>
            <% } %>

            <div class="admin-grid">
                <% classrooms.forEach(function(room) { %>
                    <article class="admin-item-card" data-search-group="classrooms">
                        <div class="admin-item-top">
                            <div class="admin-item-icon">
                                <i class="fa-solid fa-door-open"></i>
                            </div>

                            <form
                                action="/admin/classrooms/<%= room._id %>/delete"
                                method="POST"
                                onsubmit="return confirmAdminDelete('Delete this classroom?')"
                            >
                                <button class="admin-delete-btn" type="submit">
                                    Delete
                                </button>
                            </form>
                        </div>

                        <h4><%= room.classroomName %></h4>
                        <p><%= room.buildingName %> · Floor <%= room.floorNumber %></p>

                        <div class="admin-meta">
                            <span class="admin-badge">Lat: <%= room.latitude %></span>
                            <span class="admin-badge">Lng: <%= room.longitude %></span>
                            <span class="admin-badge">Radius: <%= room.radius %>m</span>
                        </div>
                    </article>
                <% }) %>
            </div>
        </section>
    </main>
</div>

</body>
<script src="/js/adminValidation.js"></script>
<script src="/js/adminSearch.js"></script>
<script src="/js/adminSidebarToggle.js"></script>
</html>