<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login | Attendify</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="/css/adminTheme.css">

<link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
>
</head>
<body class="admin-login-page">

<div class="admin-login-card">
    <div class="admin-login-head">
        <i class="fa-solid fa-shield-halved"></i>
        <h1>College Admin</h1>
        <p>Manage your college setup</p>
    </div>

    <% if (error) { %>
        <div class="alert error"><%= error %></div>
    <% } %>

    <form action="/admin/login" method="POST" class="admin-form">
        <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" placeholder="admin@college.com" required>
        </div>

        <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" placeholder="Enter password" required>
        </div>

        <button type="submit" class="btn-primary">Login as Admin</button>
    </form>

    <p class="login-links">
        <a href="/">Home</a> · <a href="/teacher/login">Teacher Login</a>
    </p>
</div>

</body>
<script src="/js/adminSidebarToggle.js"></script>
</html>
