<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Subjects | Admin</title>

    <!-- Admin theme CSS -->
    <link rel="stylesheet" href="/css/adminTheme.css">

    <!-- Font Awesome Icons -->
    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    >
    
</head>
<body>

<div class="admin-layout">

    <%- include("partials/sidebar", { activePage: activePage }) %>

    <main class="admin-main">

        <header class="admin-header">
            <div>
                <span class="admin-kicker">Admin Panel</span>
                <h1>Subjects</h1>
                <p>Create subjects and assign teachers to class groups.</p>
            </div>
        </header>

        <% if (message) { %>
            <div class="admin-alert <%= message.includes('successfully') ? 'success' : 'error' %>">
                <%= message %>
            </div>
        <% } %>

        <section class="admin-card">
            <div class="admin-card-head">
                <div>
                    <h3>Add Subject</h3>
                    <p>Assign subject to a class group and one or more teachers.</p>
                </div>
            </div>

            <form action="/admin/subjects/create" method="POST" class="admin-form-grid">

                <input
                    type="text"
                    name="subjectName"
                    placeholder="Subject Name"
                    required
                >

                <input
                    type="text"
                    name="subjectCode"
                    placeholder="Subject Code"
                    required
                >

                <input
                    type="text"
                    name="department"
                    placeholder="Department"
                    required
                >

                <input
                    type="number"
                    name="semester"
                    placeholder="Semester"
                    required
                >

                <select name="classGroupId" required>
                    <option value="">Select Class Group</option>

                    <% classGroups.forEach(function(group) { %>
                        <option
                            value="<%= group._id %>"
                            data-department="<%= group.department %>"
                            data-semester="<%= group.semester %>"
                        >
                            <%= group.name %> - Sem <%= group.semester %> <%= group.section %>
                        </option>
                    <% }) %>
                </select>

                <select name="teacherIds" multiple required>
                    <% teachers.forEach(function(teacher) { %>
                        <option value="<%= teacher._id %>">
                            <%= teacher.fullName %> - <%= teacher.department %>
                        </option>
                    <% }) %>
                </select>

                <button class="admin-primary-btn" type="submit">
                    <i class="fa-solid fa-plus"></i>
                    Add Subject
                </button>
            </form>
        </section>

        <section class="admin-card">

            <div class="admin-toolbar">
                <div class="admin-search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input
                        type="text"
                        data-admin-search="subjects"
                        placeholder="Search subject by name, code, department, class group or teacher..."
                    >
                </div>

                <span class="admin-count-pill">
                    <%= subjects.length %> Subjects
                </span>
            </div>

            <% if (!subjects || subjects.length === 0) { %>
                <div class="admin-empty">
                    No subjects found.
                </div>
            <% } %>

            <div class="admin-grid">

                <% subjects.forEach(function(subject) { %>

                    <article class="admin-item-card" data-search-group="subjects">

                        <div class="admin-item-top">
                            <div class="admin-item-icon">
                                <i class="fa-solid fa-book"></i>
                            </div>

                            <form
                                action="/admin/subjects/<%= subject._id %>/delete"
                                method="POST"
                                onsubmit="return confirmAdminDelete('Delete this subject?')"
                            >
                                <button class="admin-delete-btn" type="submit">
                                    Delete
                                </button>
                            </form>
                        </div>

                        <h4><%= subject.subjectName %></h4>
                        <p><%= subject.subjectCode %></p>

                        <div class="admin-meta">
                            <span class="admin-badge">
                                <%= subject.department %>
                            </span>

                            <span class="admin-badge">
                                Sem <%= subject.semester %>
                            </span>

                            <% if (subject.classGroup) { %>
                                <span class="admin-badge">
                                    <%= subject.classGroup.name %>
                                </span>
                            <% } else { %>
                                <span class="admin-badge">
                                    Class Missing
                                </span>
                            <% } %>
                        </div>

                        <div class="admin-meta">
                            <% if (subject.teachers && subject.teachers.length > 0) { %>
                                <% subject.teachers.forEach(function(teacher) { %>
                                    <span class="admin-badge">
                                        <i class="fa-solid fa-chalkboard-user"></i>
                                        <%= teacher.fullName %>
                                    </span>
                                <% }) %>
                            <% } else { %>
                                <span class="admin-badge">
                                    No Teacher Assigned
                                </span>
                            <% } %>
                        </div>

                    </article>

                <% }) %>

            </div>

        </section>

    </main>

</div>

</body>
<script src="/js/adminSearch.js"></script>
<script src="/js/adminSidebarToggle.js"></script>
<script src="/js/adminValidation.js"></script>
<script src="/js/adminDynamicForms.js"></script>
</html>